{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/activate.js\"",
            "timeout": 10,
            "statusMessage": "혼클로드 워크플로우 로딩..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/finish-work.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
