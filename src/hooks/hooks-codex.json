{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/activate-codex.js\"", "async": false }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/finish-work-codex.js\"" }
        ]
      }
    ]
  }
}
