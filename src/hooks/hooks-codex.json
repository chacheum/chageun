{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/activate-codex.mjs\"", "async": false }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__.*",
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/pretooluse-codex.mjs\"", "timeout": 10 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "node \"${PLUGIN_ROOT}/hooks/finish-work-codex.mjs\"" }
        ]
      }
    ]
  }
}
